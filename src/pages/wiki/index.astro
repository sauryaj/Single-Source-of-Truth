---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const wikiEntries = await getCollection('wiki');
---

<Layout title="Wiki | SSOT">
	<div class="space-y-12">
		<div class="text-center space-y-4">
			<h1 class="text-4xl font-extrabold text-slate-900">Licensing & Knowledge Wiki</h1>
			<p class="text-slate-600 max-w-xl mx-auto">
				Plain-English explanations of complex cloud licensing and technical laws. No jargon, just the facts.
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			{wikiEntries.map(entry => (
				<a href={`/wiki/${entry.slug}`} class="p-6 bg-white border border-slate-200 rounded-xl hover:border-blue-500 transition-all group">
					<div class="flex justify-between items-start mb-2">
						<h3 class="text-lg font-bold text-slate-900 group-hover:text-blue-600 transition-colors">{entry.data.title}</h3>
						<span class="text-xs font-medium bg-blue-50 text-blue-600 px-2 py-1 rounded">{entry.data.category || 'General'}</span>
					</div>
					<p class="text-slate-600 text-sm line-clamp-2">Deep dive into {entry.data.title} and its implications.</p>
				</a>
			))}
		</div>
	</div>
</Layout>
