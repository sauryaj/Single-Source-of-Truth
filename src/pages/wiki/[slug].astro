---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const wikiEntries = await getCollection('wiki');
	return wikiEntries.map(entry => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | SSOT Wiki`}>
	<article class="max-w-3xl mx-auto">
		<header class="mb-12 space-y-4">
			<div class="flex items-center gap-3 text-sm font-medium text-blue-600">
				<a href="/wiki" class="hover:underline">← Back to Wiki</a>
			</div>
			<div class="flex items-center gap-3">
				<h1 class="text-4xl font-extrabold text-slate-900">{entry.data.title}</h1>
				<span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-bold">{entry.data.category}</span>
			</div>
		</header>
		
		<div class="prose prose-slate max-w-none">
			<Content />
		</div>
	</article>
</Layout>
