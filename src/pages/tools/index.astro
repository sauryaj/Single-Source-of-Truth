---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Free Tools | SSOT">
	<div class="space-y-12">
		<div class="text-center space-y-4">
			<h1 class="text-4xl font-extrabold text-slate-900">Free IT Tools</h1>
			<p class="text-slate-600 max-w-xl mx-auto">
				Utility tools for Cloud and AI engineers. No sign-ups, no tracking, no cost.
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<a href="/tools/prompt-architect" class="p-6 bg-white border border-slate-200 rounded-2xl hover:border-blue-500 transition-all group">
				<div class="flex items-center gap-4 mb-4">
					<div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-slate-900">Prompt Architect</h3>
				</div>
				<p class="text-slate-600 text-sm">Build high-performance AI system prompts using the Role-Task-Constraint framework.</p>
				<div class="mt-4 text-blue-600 font-semibold text-sm group-hover:translate-x-1 transition-transform">
					Launch Tool →
				</div}
			</a>

			<!-- Placeholder for future tools -->
			<div class="p-6 bg-slate-50 border border-dashed border-slate-300 rounded-2xl flex flex-col items-center justify-center text-center space-y-2">
				<span class="text-slate-400 text-sm font-medium italic">Next tool coming soon...</span>
			</div>
		</div}
	</div>
</Layout>
