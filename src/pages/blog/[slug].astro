---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const blogPosts = await getCollection('blog');
	return blogPosts.map(entry => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | SSOT Blog`}>
	<article class="max-w-3xl mx-auto">
		<header class="mb-12 space-y-4 text-center">
			<div class="flex justify-center items-center gap-3 text-sm font-medium text-blue-600">
				<a href="/blog" class="hover:underline">← Back to Blog</a>
			</div>
			<h1 class="text-4xl font-extrabold text-slate-900">{entry.data.title}</h1>
			<div class="text-slate-500 text-sm font-mono">
				Published on {entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
			</div>
		</header>
		
		<div class="prose prose-slate max-w-none">
			<Content />
		</div>
	</article>
</Layout>
