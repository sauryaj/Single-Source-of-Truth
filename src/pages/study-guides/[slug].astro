---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const studyGuides = await getCollection('study-guides');
	return studyGuides.map(entry => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | SSOT`}>
	<article class="max-w-3xl mx-auto">
		<header class="mb-12 space-y-4">
			<div class="flex items-center gap-3 text-sm font-medium text-blue-600">
				<a href="/study-guides" class="hover:underline">← Back to Guides</a>
			</div>
			<h1 class="text-4xl font-extrabold text-slate-900">{entry.data.title}</h1>
			<div class="flex flex-wrap gap-3">
				{entry.data.examCode && <span class="px-3 py-1 bg-slate-200 text-slate-700 rounded-full text-xs font-bold">{entry.data.examCode}</span>}
				{entry.data.difficulty && <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-bold">{entry.data.difficulty}</span>}
			</div>
			{entry.data.officialLink && (
				<a href={entry.data.officialLink} target="_blank" class="inline-flex items-center text-sm text-blue-600 hover:underline">
					View Official Documentation ↗
				</a>
			)}
		</header>
		
		<div class="prose prose-slate max-w-none">
			<Content />
		</div>
	</article>
</Layout>
