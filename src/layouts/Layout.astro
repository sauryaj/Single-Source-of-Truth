---
import '../styles/global.css';
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased">
		<nav class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-slate-200">
			<div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
				<a href="/" class="font-bold text-xl tracking-tight text-slate-900 hover:text-blue-600 transition-colors">
					SSOT<span class="text-blue-600">.</span>
				</a>
				<div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
					<a href="/study-guides" class="hover:text-blue-600 transition-colors">Study Guides</a>
					<a href="/wiki" class="hover:text-blue-600 transition-colors">Wiki</a>
					<a href="/blog" class="hover:text-blue-600 transition-colors">Blog</a>
					<a href="https://ko-fi.com" class="bg-blue-600 text-white px-4 py-2 rounded-full hover:bg-blue-700 transition-all">Support Me</a>
				</div>
			</div>
		</nav>
		<main class="max-w-5xl mx-auto px-4 py-12">
			<slot />
		</main>
		<footer class="border-t border-slate-200 py-12 bg-white">
			<div class="max-w-5xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6 text-slate-500 text-sm">
				<p>© {new Date().getFullYear()} Single Source of Truth. Built for clarity.</p>
				<div class="flex gap-6">
					<a href="#" class="hover:text-slate-900 transition-colors">Twitter</a>
					<a href="#" class="hover:text-slate-900 transition-colors">GitHub</a>
					<a href="#" class="hover:text-slate-900 transition-colors">LinkedIn</a>
				</div>
			</div>
		</footer>
	</body>
</html>
